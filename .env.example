# Database
DB_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql://finance:change-me-to-a-strong-password@localhost:5432/finance_tracker

# NextAuth / Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://finance.srv1068566.hstgr.cloud

# Web Push — generate with: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same value as VAPID_PUBLIC_KEY (exposed to browser)
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Cron secret — protect /api/v1/cron/reminders endpoint
CRON_SECRET=generate-a-random-secret-string

# App
NODE_ENV=production
